# Doppelganger - Environment Variables Example
# Copy this file to .env.local and fill in your keys.

# Groq API Key (for Llama 3.3 70B analysis)
GROQ_API_KEY=your_groq_key_here

# Tavily API Key (for MCP real-time web search)
TAVILY_API_KEY=your_tavily_key_here

# Model Context Protocol (MCP) configuration is handled automatically 
# via the Tavily MCP SSE endpoint in the API routes.
